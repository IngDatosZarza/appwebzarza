APP_NAME="Sistema de Puntos Zarza"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Mexico_City
APP_URL=http://contigo.lazarza.com.mx

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Base de datos remota - ACTUALIZAR CON TUS CREDENCIALES
DB_CONNECTION=mysql
DB_HOST=tu-servidor-remoto-mysql.com
DB_PORT=3306
DB_DATABASE=nombre_base_datos
DB_USERNAME=usuario_db
DB_PASSWORD=contraseña_segura

# Configuración de sesiones
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Configuración de caché
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=zarza_

# Configuración de correo - Hostinger SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@lazarza.com.mx
MAIL_PASSWORD=tu-password-seguro
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@lazarza.com.mx
MAIL_FROM_NAME="${APP_NAME}"

# AWS (si lo usas para almacenamiento)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher (si lo usas)
VITE_APP_NAME="${APP_NAME}"
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# API de Oppen - ACTUALIZAR CON TUS CREDENCIALES
OPPEN_API_URL=https://api.oppen.com.mx/v1
OPPEN_API_KEY=tu-api-key-de-oppen
OPPEN_API_SECRET=tu-api-secret-de-oppen
OPPEN_API_TIMEOUT=30

# Configuración de seguridad
SANCTUM_STATEFUL_DOMAINS=contigo.lazarza.com.mx
SESSION_DOMAIN=.lazarza.com.mx

# Configuración de puntos (ejemplo - ajustar según tus reglas de negocio)
PUNTOS_POR_PESO=1
PUNTOS_MINIMOS_CANJE=100
DIAS_EXPIRACION_PUNTOS=365

# Timezone de la aplicación
APP_TIMEZONE=America/Mexico_City
